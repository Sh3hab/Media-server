    {
      "id": "season_1771911752178_hit6nzbs4",
      "seriesId": "series_1771911719297_bcduyb4xz",
      "seriesTitle": "Wednesday addams",
      "seasonNumber": 1,
      "title": "الموسم الاول",
      "poster": "/uploads/posters/1771911679814-852076563.jpeg",
      "description": "تدور أحداث المسلسل حول وينزداي آدامز، الفتاة الذكية والغامضة ذات الحس الساخر، أثناء دراستها في أكاديمية نيفرمور. تحاول وينزداي إتقان قدراتها النفسية الناشئة، وإحباط سلسلة جرائم قتل مرعبة أرعبت البلدة المحلية، وكشف لغز خارق للطبيعة تورط فيه والداها قبل 25 عامًا — كل ذلك أثناء تعاملها مع علاقاتها المعقدة في المدرسة.",
      "year": 2022,
      "episodeCount": 4,
      "createdAt": "2026-02-24T05:42:32.178Z",
